            200
          ],
          "justifyContent": "center",
          "children": [
            {
              "type": "text",
              "id": "fFfcc",
              "name": "The Solution",
              "fill": {
                "type": "gradient",
                "gradientType": "linear",
                "enabled": true,
                "rotation": -450,
                "size": {
                  "height": 1
                },
                "colors": [
                  {

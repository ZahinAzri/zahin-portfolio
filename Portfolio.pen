                          ]
                        }
                      ],
                      "content": "03",
                      "lineHeight": 1.1,
                      "fontFamily": "Rounded Mplus 1c Bold",
                      "fontSize": 40,
                      "fontWeight": "700",
                      "letterSpacing": -8.4
                    },
                    {
                      "type": "text",
                      "id": "mrVDc",
                      "name": "There was no established brand to work from. The interface was generic, with nothing that reflected the weight or identity of what Kad Pekerja Madani was meant to represent.",
                      "fill": "#e0e0e0ff",
                      "textGrowth": "fixed-width",
                      "width": "fill_container",
                      "content": "There was no established brand to work from. The interface was generic, with nothing that reflected the weight or identity of what Kad Pekerja Madani was meant to represent.",
                      "fontFamily": "Satoshi",
                      "fontSize": 24,
                      "fontWeight": "normal"
                    }
                  ]
                }
              ]
            }
          ]
        },
        {
          "type": "frame",
          "id": "eIttU",
          "name": "Frame 22",
          "width": "fill_container",
          "fill": {
            "type": "color",

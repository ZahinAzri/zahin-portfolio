                      "fill": [
                        "#ffffffff",
                        {
                          "type": "gradient",
                          "gradientType": "linear",
                          "enabled": true,
                          "rotation": -450,
                          "size": {
                            "height": 1
                          },
                          "colors": [
                            {
                              "color": "#b5d3e9ff",
                              "position": 0
                            },
                            {
                              "color": "#cc9d96ff",
                              "position": 1
